{
  "name": "wiki-app",
  "version": "1.0.0",
  "description": "AI-powered personal knowledge base",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "unset ELECTRON_RUN_AS_NODE && electron .",
    "dist": "unset ELECTRON_RUN_AS_NODE && electron-builder --mac dmg",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gongty/wiki-app.git"
  },
  "keywords": [
    "wiki",
    "knowledge-base",
    "ai",
    "llm",
    "rag"
  ],
  "author": "gongty",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/gongty/wiki-app/issues"
  },
  "homepage": "https://github.com/gongty/wiki-app#readme",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.0.2",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.blank.pith",
    "productName": "Pith",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "server.js",
      "electron/**/*",
      "app/**/*",
      "lib/**/*",
      "scripts/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/system-sources.json",
        "to": "data/system-sources.json"
      }
    ]
  }
}
